<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext traffic for scraper sources that don't support HTTPS -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">wuxia.blog</domain>
        <domain includeSubdomains="true">1stkissnovel.org</domain>
    </domain-config>

    <!-- Allow cleartext traffic for local network sync (development/LAN) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.0.0</domain>
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">192.168.1.104</domain>
        <domain includeSubdomains="true">172.16.0.0</domain>
    </domain-config>
</network-security-config>
